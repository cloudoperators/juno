{
  "name": "@cloudoperators/juno-app-heureka",
  "version": "1.1.1",
  "author": "UI-Team",
  "type": "module",
  "repository": "https://github.com/cloudoperators/juno/tree/main/apps/heureka",
  "license": "Apache-2.0",
  "source": "src/index.js",
  "exports": {
    ".": {
      "types": "./src/types/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:static": "vite build --mode static",
    "generate:types": "graphql-codegen --config codegen.ts",
    "postgenerate:types": "prettier --log-level warn --write ./src/generated/graphql.ts",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "clean": "rm -rf build && rm -rf node_modules && rm -rf .turbo",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean:cache": "rm -rf .turbo"
  },
  "dependencies": {
    "@cloudoperators/greenhouse-auth-provider": "workspace:*",
    "@cloudoperators/juno-ui-components": "workspace:*",
    "@cloudoperators/juno-url-state-provider": "workspace:*",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.22",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@apollo/client": "4.1.7",
    "@cloudoperators/juno-config": "workspace:*",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "5.0.9",
    "@graphql-codegen/typescript-react-apollo": "4.4.1",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/router-plugin": "1.167.22",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.4",
    "autoprefixer": "10.4.27",
    "eslint": "10.1.0",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-tailwindcss": "3.18.3",
    "jsdom": "26.1.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "react-error-boundary": "6.1.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vite-plugin-svgr": "4.5.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  }
}
