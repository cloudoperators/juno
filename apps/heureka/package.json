{
  "name": "@cloudoperators/juno-app-heureka",
  "version": "1.1.6",
  "author": "UI-Team",
  "type": "module",
  "repository": "https://github.com/cloudoperators/juno/tree/main/apps/heureka",
  "license": "Apache-2.0",
  "source": "src/index.js",
  "exports": {
    ".": {
      "types": "./src/types/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:static": "vite build --mode static",
    "generate:types": "graphql-codegen --config codegen.ts",
    "postgenerate:types": "prettier --log-level warn --write ./src/generated/graphql.ts",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "clean": "rm -rf build && rm -rf node_modules && rm -rf .turbo",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean:cache": "rm -rf .turbo"
  },
  "dependencies": {
    "@cloudoperators/greenhouse-auth-provider": "workspace:*",
    "@cloudoperators/juno-ui-components": "workspace:*",
    "@cloudoperators/juno-url-state-provider": "workspace:*",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-router": "1.170.9",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@apollo/client": "4.1.9",
    "@cloudoperators/juno-config": "workspace:*",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "5.1.0",
    "@graphql-codegen/typescript-react-apollo": "4.4.2",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-plugin": "1.168.12",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/ui": "4.1.7",
    "dotenv": "17.4.2",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "react-error-boundary": "6.1.2",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7"
  }
}
